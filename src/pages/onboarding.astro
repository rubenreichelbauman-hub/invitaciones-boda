---
// src/pages/onboarding.astro
// Herramienta interna: genera un config.json listo para pegar en src/data/config.json
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cuéntanos sobre su boda</title>
    <style is:global>
      :root {
        --paper: #f6f5f3;
        --ink: #1e1c1a;
        --accent: #9c7a4a;
        --accent-contrast: #ffffff;
      }
      * { box-sizing: border-box; }
      [hidden] { display: none !important; }
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: var(--paper);
        color: var(--ink);
        padding: 2.5rem 1.5rem 6rem;
        transition: background-color 0.25s ease, color 0.25s ease;
      }
      .wrap { max-width: 720px; margin: 0 auto; }
      h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
      .subtitle { opacity: 0.7; font-size: 0.9rem; margin-bottom: 2.5rem; }
      fieldset {
        border: 1px solid var(--accent);
        border-radius: 10px;
        padding: 1.25rem 1.5rem 1.5rem;
        margin-bottom: 1.75rem;
        background: #fff;
        transition: border-color 0.25s ease;
      }
      legend {
        font-weight: 600;
        font-size: 0.95rem;
        padding: 0 0.4rem;
        color: var(--ink);
      }
      label {
        display: block;
        font-size: 0.85rem;
        margin-bottom: 1rem;
      }
      label span { display: block; margin-bottom: 0.3rem; opacity: 0.75; }
      input, textarea, select {
        width: 100%;
        font-size: 0.9rem;
        padding: 0.55rem 0.7rem;
        border: 1px solid #ccc4ba;
        border-radius: 6px;
        font-family: inherit;
      }
      textarea { resize: vertical; }
      .row { display: flex; gap: 1rem; }
      .row > label { flex: 1; }
      .clearable-wrap { position: relative; }
      .clearable-wrap input, .clearable-wrap textarea { padding-right: 1.9rem; }
      .clear-input-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.35rem;
        width: 1.3rem;
        height: 1.3rem;
        padding: 0;
        border: none;
        background: none;
        border-radius: 50%;
        cursor: pointer;
        font-size: 1rem;
        line-height: 1;
        opacity: 0.4;
        color: var(--ink);
      }
      .clear-input-btn:hover { opacity: 0.85; }
      .color-row input[type="color"] { height: 2.3rem; padding: 0.2rem; }
      .color-row { margin-top: 1rem; }
      .palette-options {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
        gap: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .palette-option {
        display: block;
      }
      .palette-option input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
      }
      .palette-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        height: 100%;
        box-sizing: border-box;
        border: 1px solid #ccc4ba;
        border-radius: 8px;
        padding: 0.7rem 0.9rem;
        cursor: pointer;
        text-align: center;
      }
      .palette-option input:checked + .palette-card {
        border-color: var(--ink);
        box-shadow: 0 0 0 1px var(--ink);
      }
      .swatch-group { display: flex; }
      .swatch {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1px solid rgba(0, 0, 0, 0.15);
        margin-left: -6px;
      }
      .swatch:first-child { margin-left: 0; }
      .palette-label { font-size: 0.78rem; opacity: 0.8; }
      .event-block {
        border: 1px dashed #ccc4ba;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
        position: relative;
      }
      .remove-event {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        z-index: 1;
        background: none;
        border: none;
        cursor: pointer;
        opacity: 0.5;
        font-size: 0.9rem;
      }
      .remove-event:hover { opacity: 1; }
      .itinerary-omit {
        font-size: 0.75rem;
        border: 1px solid #ccc4ba;
        border-radius: 6px;
        padding: 0.2rem 0.55rem;
      }
      .add-btn, .generate-btn {
        font-size: 0.85rem;
        border: 1px solid var(--accent);
        background: var(--accent);
        color: var(--accent-contrast);
        border-radius: 6px;
        padding: 0.6rem 1.1rem;
        cursor: pointer;
        transition: background-color 0.25s ease, border-color 0.25s ease, color 0.25s ease;
      }
      .add-btn {
        background: none;
        color: var(--accent);
      }
      .add-btn:hover { background: var(--paper); }
      .generate-btn { display: block; width: 100%; padding: 0.9rem; font-size: 0.95rem; margin-top: 0.5rem; }
      .generate-btn:disabled { opacity: 0.6; cursor: default; }
      .error-text { color: #b3261e; font-size: 0.85rem; margin-top: 0.75rem; }
      #thanks-section { margin-top: 2.5rem; }
      #thanks-message { font-size: 1rem; line-height: 1.5; margin: 0; }
      .field-hint { font-size: 0.8rem; opacity: 0.65; margin: 0 0 0.75rem 0; line-height: 1.4; }
      .photo-email-menu {
        margin-top: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        max-width: 280px;
      }
      .photo-email-menu a {
        display: block;
        text-align: center;
        text-decoration: none;
        font-size: 0.85rem;
        border: 1px solid #ccc4ba;
        border-radius: 6px;
        padding: 0.6rem 1rem;
        color: #1e1c1a;
      }
      .photo-email-menu a:hover { background: #eee9e2; }
      .draft-notice {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border: 1px solid var(--accent);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        background: #fff;
      }
      .draft-notice button { flex-shrink: 0; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <h1>Cuéntanos sobre su boda</h1>
      <p class="subtitle">
        Completen esta información entre los dos. Al enviarla, comenzamos a
        construir su invitación digital.
      </p>

      <div id="draft-notice" class="draft-notice" hidden>
        <span>Recuperamos la información que habías guardado en este navegador.</span>
        <button type="button" id="discard-draft-btn" class="add-btn">Empezar de nuevo</button>
      </div>

      <form id="onboarding-form">
        <fieldset>
          <legend>La pareja</legend>
          <div class="row">
            <label><span>Nombre 1</span><input type="text" name="name1" required /></label>
            <label><span>Nombre 2</span><input type="text" name="name2" required /></label>
          </div>
          <label><span>Hashtag</span><input type="text" name="hashtag" placeholder="#AnaYCarlos2026" /></label>
        </fieldset>

        <fieldset>
          <legend>Tema y colores</legend>
          <label>
            <span>Tema</span>
            <select name="theme">
              <option value="elegante">Elegante clásico</option>
              <option value="bohemio">Bohemio / Boho</option>
              <option value="minimalista">Minimalista moderno</option>
              <option value="moderno">Moderno audaz</option>
            </select>
          </label>

          <p class="field-hint">Elige una paleta de colores o personaliza la tuya.</p>
          <div id="palette-options" class="palette-options"></div>

          <div id="custom-colors" class="row color-row" hidden>
            <label><span>Color tinta (texto)</span><input type="color" id="custom-ink" value="#2B2320" /></label>
            <label><span>Color papel (fondo)</span><input type="color" id="custom-paper" value="#F1ECE4" /></label>
            <label><span>Color acento</span><input type="color" id="custom-accent" value="#9C7A4A" /></label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Fecha y contenido</legend>
          <label><span>Fecha y hora de la boda</span><input type="datetime-local" name="date" required /></label>
          <label><span>Nuestra historia</span><textarea name="story" rows="3"></textarea></label>
        </fieldset>

        <fieldset>
          <legend>Eventos</legend>
          <div id="events-container"></div>
          <button type="button" id="add-event" class="add-btn">+ Agregar evento</button>
        </fieldset>

        <fieldset>
          <legend>Itinerario</legend>
          <p class="field-hint">
            Cada momento es importante, no olvides compartirlo para que tus invitados no se
            pierdan nada del gran día.
          </p>
          <div id="itinerary-container"></div>
          <button type="button" id="add-itinerary-item" class="add-btn">+ Agregar momento</button>
        </fieldset>

        <fieldset>
          <legend>Detalles</legend>
          <label><span>Código de vestimenta</span><input type="text" name="dressCode" placeholder="Formal · tonos tierra" /></label>
          <label><span>Fecha límite para RSVP</span><input type="date" name="rsvpDeadline" /></label>
        </fieldset>

        <fieldset>
          <legend>Fotos</legend>
          <p class="field-hint">
            Mándanos tus fotos por correo indicando cuál es la portada. Así evitamos
            retrasos por el tamaño de los archivos.
          </p>
          <div id="photo-email-menu" class="photo-email-menu">
            <a id="photo-email-gmail" target="_blank" rel="noopener">Abrir en Gmail</a>
            <a id="photo-email-outlook" target="_blank" rel="noopener">Abrir en Outlook</a>
            <a id="photo-email-default">Abrir mi correo predeterminado</a>
          </div>
        </fieldset>

        <fieldset>
          <legend>Mesa de regalos</legend>
          <p class="field-hint">
            Si tienen mesa en más de un lugar (tienda departamental, en línea, etc.),
            agrega todas las que necesites.
          </p>
          <div id="registries-container"></div>
          <button type="button" id="add-registry" class="add-btn">+ Agregar mesa de regalos</button>
          <label style="margin-top: 1.25rem;"><span>Datos bancarios</span><textarea name="bankInfo" rows="3" placeholder="Banco: ...&#10;Cuenta: ...&#10;A nombre de: ..."></textarea></label>
        </fieldset>

        <button type="submit" id="submit-btn" class="generate-btn">Enviar y construir mi invitación</button>
        <p id="submit-error" class="error-text" hidden>
          No pudimos enviar la información. Revisa tu conexión e intenta de nuevo.
        </p>
      </form>

      <div id="thanks-section" hidden>
        <fieldset>
          <legend>¡Gracias!</legend>
          <p id="thanks-message"></p>
        </fieldset>
      </div>
    </div>

    <template id="registry-template">
      <div class="event-block">
        <button type="button" class="remove-event" aria-label="Quitar mesa de regalos">&times;</button>
        <label><span>Nombre de la tienda</span><input type="text" class="registry-label" placeholder="Liverpool, Amazon, etc." /></label>
        <label><span>URL de la mesa</span><input type="text" class="registry-url" placeholder="https://..." /></label>
      </div>
    </template>

    <template id="event-template">
      <div class="event-block">
        <button type="button" class="remove-event" aria-label="Quitar evento">&times;</button>
        <label><span>Nombre del evento</span><input type="text" class="ev-name" placeholder="Ceremonia" /></label>
        <div class="row">
          <label><span>Hora</span><input type="text" class="ev-time" placeholder="17:00" /></label>
          <label><span>Lugar</span><input type="text" class="ev-location" placeholder="Iglesia San José" /></label>
        </div>
        <label><span>Dirección completa</span><input type="text" class="ev-address" /></label>
        <label>
          <span>URL de embed de Google Maps (opcional)</span>
          <input type="text" class="ev-map" placeholder="https://www.google.com/maps/embed?pb=..." />
          <small style="display:block;opacity:0.6;margin-top:0.3rem;">
            Debe ser el link de "Insertar un mapa" (botón Compartir → pestaña Insertar un mapa → Copiar HTML,
            usa solo la URL del src). El link normal para compartir (maps.app.goo.gl/...) no funciona aquí.
          </small>
        </label>
      </div>
    </template>

    <template id="itinerary-template">
      <div class="event-block itinerary-block">
        <button type="button" class="remove-event itinerary-omit" aria-label="Omitir este momento">Omitir</button>
        <div class="row">
          <label><span>Hora</span><input type="text" class="it-time" placeholder="20:00" /></label>
          <label>
            <span>Icono</span>
            <select class="it-icon">
              <option value="church">⛪ Ceremonia</option>
              <option value="camera">📷 Fotos</option>
              <option value="toast">🥂 Cóctel / brindis</option>
              <option value="dinner">🍽️ Cena</option>
              <option value="rings">💍 Baile / anillos</option>
              <option value="cake">🎂 Pastel</option>
              <option value="party">🎉 Fiesta</option>
              <option value="heart">❤️ Cierre</option>
            </select>
          </label>
        </div>
        <label><span>Descripción del momento</span><input type="text" class="it-title" placeholder="Inicia la ceremonia civil" /></label>
      </div>
    </template>

    <script>
      const THEME_PALETTES = {
        elegante: [
          { key: 'elegante-marfil', label: 'Marfil clásico', ink: '#2B2320', paper: '#F1ECE4', accent: '#9C7A4A' },
          { key: 'elegante-marino', label: 'Azul marino y oro', ink: '#1E2A38', paper: '#F4F1EA', accent: '#B08D57' },
          { key: 'elegante-vino', label: 'Vino tinto', ink: '#2E1A22', paper: '#F5EDE7', accent: '#7A2E3B' },
        ],
        bohemio: [
          { key: 'boho-terracota', label: 'Terracota', ink: '#3D2B1F', paper: '#F4E9DD', accent: '#C1694F' },
          { key: 'boho-oliva', label: 'Verde oliva', ink: '#33301F', paper: '#F6F1E4', accent: '#8A8B4F' },
          { key: 'boho-rosa', label: 'Rosa palo', ink: '#3B2A2E', paper: '#F7EDE9', accent: '#C98A82' },
        ],
        minimalista: [
          { key: 'min-gris', label: 'Gris piedra', ink: '#24272B', paper: '#F5F5F3', accent: '#9AA5B1' },
          { key: 'min-sage', label: 'Verde sage', ink: '#222420', paper: '#F6F5F1', accent: '#A7B49E' },
          { key: 'min-mono', label: 'Blanco y negro', ink: '#111111', paper: '#FAFAFA', accent: '#C9A876' },
        ],
        moderno: [
          { key: 'moderno-rojo', label: 'Blanco y negro editorial', ink: '#000000', paper: '#FFFFFF', accent: '#E63946' },
          { key: 'moderno-azul', label: 'Azul eléctrico', ink: '#0B0B0F', paper: '#FFFFFF', accent: '#2D6CDF' },
          { key: 'moderno-esmeralda', label: 'Verde esmeralda', ink: '#0D0D0D', paper: '#FFFFFF', accent: '#0FA968' },
        ],
      };

      const themeSelect = document.querySelector('select[name="theme"]');
      const paletteOptions = document.getElementById('palette-options');
      const customColors = document.getElementById('custom-colors');
      const customInk = document.getElementById('custom-ink');
      const customPaper = document.getElementById('custom-paper');
      const customAccent = document.getElementById('custom-accent');

      let currentPalettes = THEME_PALETTES[themeSelect.value];
      let lastPalette = currentPalettes[0];

      function renderPalettesForTheme(themeKey) {
        currentPalettes = THEME_PALETTES[themeKey];
        lastPalette = currentPalettes[0];
        customColors.hidden = true;
        paletteOptions.innerHTML = '';

        currentPalettes.forEach((palette, index) => {
          const label = document.createElement('label');
          label.className = 'palette-option';
          label.innerHTML = `
            <input type="radio" name="palette" value="${palette.key}" ${index === 0 ? 'checked' : ''} />
            <span class="palette-card">
              <span class="swatch-group">
                <span class="swatch" style="background:${palette.ink}"></span>
                <span class="swatch" style="background:${palette.paper}"></span>
                <span class="swatch" style="background:${palette.accent}"></span>
              </span>
              <span class="palette-label">${palette.label}</span>
            </span>
          `;
          paletteOptions.appendChild(label);
        });

        const customLabel = document.createElement('label');
        customLabel.className = 'palette-option';
        customLabel.innerHTML = `
          <input type="radio" name="palette" value="custom" />
          <span class="palette-card">
            <span class="swatch-group">
              <span class="swatch" style="background:#fff;border-style:dashed;"></span>
            </span>
            <span class="palette-label">Personalizar</span>
          </span>
        `;
        paletteOptions.appendChild(customLabel);
        applyPreviewColors(getSelectedColors());
      }

      function hexToRgb(hex) {
        const clean = hex.replace('#', '');
        const bigint = parseInt(clean, 16);
        return { r: (bigint >> 16) & 255, g: (bigint >> 8) & 255, b: bigint & 255 };
      }

      function relativeLuminance({ r, g, b }) {
        const channel = (c) => {
          const s = c / 255;
          return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
        };
        return 0.2126 * channel(r) + 0.7152 * channel(g) + 0.0722 * channel(b);
      }

      function contrastTextColor(hex) {
        return relativeLuminance(hexToRgb(hex)) > 0.5 ? '#1e1c1a' : '#ffffff';
      }

      function applyPreviewColors(colors) {
        const root = document.documentElement.style;
        root.setProperty('--paper', colors.paper);
        root.setProperty('--ink', colors.ink);
        root.setProperty('--accent', colors.accent);
        root.setProperty('--accent-contrast', contrastTextColor(colors.accent));
      }

      themeSelect.addEventListener('change', () => renderPalettesForTheme(themeSelect.value));
      renderPalettesForTheme(themeSelect.value);

      paletteOptions.addEventListener('change', (e) => {
        const value = e.target.value;
        if (value === 'custom') {
          customColors.hidden = false;
          customInk.value = lastPalette.ink;
          customPaper.value = lastPalette.paper;
          customAccent.value = lastPalette.accent;
        } else {
          customColors.hidden = true;
          lastPalette = currentPalettes.find((p) => p.key === value);
        }
        applyPreviewColors(getSelectedColors());
      });

      [customInk, customPaper, customAccent].forEach((input) =>
        input.addEventListener('input', () => applyPreviewColors(getSelectedColors()))
      );

      function getSelectedColors() {
        const selected = document.querySelector('input[name="palette"]:checked').value;
        if (selected === 'custom') {
          return { ink: customInk.value, paper: customPaper.value, accent: customAccent.value };
        }
        const palette = currentPalettes.find((p) => p.key === selected);
        return { ink: palette.ink, paper: palette.paper, accent: palette.accent };
      }

      function makeClearable(el) {
        if (el.closest('.clearable-wrap')) return;
        const wrap = document.createElement('div');
        wrap.className = 'clearable-wrap';
        el.parentNode.insertBefore(wrap, el);
        wrap.appendChild(el);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'clear-input-btn';
        btn.textContent = '×';
        btn.setAttribute('aria-label', 'Borrar contenido');
        btn.hidden = !el.value;
        wrap.appendChild(btn);

        el.addEventListener('input', () => { btn.hidden = !el.value; });
        btn.addEventListener('click', () => {
          el.value = '';
          btn.hidden = true;
          el.dispatchEvent(new Event('input', { bubbles: true }));
          el.dispatchEvent(new Event('change', { bubbles: true }));
          el.focus();
        });
      }

      function makeAllClearable(root) {
        root.querySelectorAll('input[type="text"], textarea').forEach(makeClearable);
      }

      function refreshClearButton(el) {
        const btn = el.nextElementSibling;
        if (btn && btn.classList.contains('clear-input-btn')) {
          btn.hidden = !el.value;
        }
      }

      const DRAFT_KEY = 'onboarding-draft-v1';
      let autosaveEnabled = false;

      const eventsContainer = document.getElementById('events-container');
      const eventTemplate = document.getElementById('event-template');

      function addEvent(defaults = {}) {
        const clone = eventTemplate.content.cloneNode(true);
        const block = clone.querySelector('.event-block');
        if (defaults.name) block.querySelector('.ev-name').value = defaults.name;
        if (defaults.time) block.querySelector('.ev-time').value = defaults.time;
        if (defaults.location) block.querySelector('.ev-location').value = defaults.location;
        if (defaults.address) block.querySelector('.ev-address').value = defaults.address;
        if (defaults.mapEmbedUrl) block.querySelector('.ev-map').value = defaults.mapEmbedUrl;
        block.querySelector('.remove-event').addEventListener('click', () => {
          block.remove();
          saveDraft();
        });
        eventsContainer.appendChild(clone);
        makeAllClearable(block);
        saveDraft();
      }

      document.getElementById('add-event').addEventListener('click', () => addEvent());
      addEvent({ name: 'Ceremonia' });
      addEvent({ name: 'Recepción' });

      const registriesContainer = document.getElementById('registries-container');
      const registryTemplate = document.getElementById('registry-template');

      function addRegistry(defaults = {}) {
        const clone = registryTemplate.content.cloneNode(true);
        const block = clone.querySelector('.event-block');
        if (defaults.label) block.querySelector('.registry-label').value = defaults.label;
        if (defaults.url) block.querySelector('.registry-url').value = defaults.url;
        block.querySelector('.remove-event').addEventListener('click', () => {
          block.remove();
          saveDraft();
        });
        registriesContainer.appendChild(clone);
        makeAllClearable(block);
        saveDraft();
      }

      document.getElementById('add-registry').addEventListener('click', () => addRegistry());
      addRegistry();

      const itineraryContainer = document.getElementById('itinerary-container');
      const itineraryTemplate = document.getElementById('itinerary-template');

      function addItineraryItem(defaults = {}) {
        const clone = itineraryTemplate.content.cloneNode(true);
        const block = clone.querySelector('.itinerary-block');
        if (defaults.time) block.querySelector('.it-time').value = defaults.time;
        if (defaults.title) block.querySelector('.it-title').value = defaults.title;
        if (defaults.icon) block.querySelector('.it-icon').value = defaults.icon;
        block.querySelector('.remove-event').addEventListener('click', () => {
          block.remove();
          saveDraft();
        });
        itineraryContainer.appendChild(clone);
        makeAllClearable(block);
        saveDraft();
      }

      function timeToMinutes(value) {
        const match = value.trim().match(/^(\d{1,2}):(\d{2})$/);
        if (!match) return null;
        const hours = Number(match[1]);
        const minutes = Number(match[2]);
        if (hours > 23 || minutes > 59) return null;
        return hours * 60 + minutes;
      }

      function sortItineraryByTime() {
        const blocks = Array.from(itineraryContainer.querySelectorAll('.itinerary-block'));
        const ordered = blocks
          .map((block) => ({
            block,
            minutes: timeToMinutes(block.querySelector('.it-time').value) ?? Infinity,
          }))
          .sort((a, b) => a.minutes - b.minutes);
        ordered.forEach(({ block }) => itineraryContainer.appendChild(block));
      }

      itineraryContainer.addEventListener('change', (e) => {
        if (e.target.classList.contains('it-time')) sortItineraryByTime();
      });

      document.getElementById('add-itinerary-item').addEventListener('click', () => addItineraryItem());
      const DEFAULT_ITINERARY = [
        { time: '13:00', title: 'Ceremonia Civil', icon: 'church' },
        { time: '17:00', title: 'Ceremonia Religiosa', icon: 'church' },
        { time: '18:00', title: 'Sesión de fotos', icon: 'camera' },
        { time: '19:00', title: 'Recepción', icon: 'toast' },
        { time: '19:30', title: 'Cóctel de bienvenida', icon: 'toast' },
        { time: '20:00', title: 'Primer baile de los novios', icon: 'rings' },
        { time: '20:30', title: 'Cena', icon: 'dinner' },
        { time: '21:30', title: 'Fiesta', icon: 'party' },
        { time: '23:30', title: 'Fin del gran día', icon: 'heart' },
      ];
      DEFAULT_ITINERARY.forEach((item) => addItineraryItem(item));

      makeAllClearable(document);

      const name1Input = document.querySelector('input[name="name1"]');
      const name2Input = document.querySelector('input[name="name2"]');
      const dateInput = document.querySelector('input[name="date"]');
      const hashtagInput = document.querySelector('input[name="hashtag"]');

      let hashtagAuto = true;

      function cleanNameForHashtag(name) {
        return name
          .normalize('NFD')
          .replace(/[̀-ͯ]/g, '')
          .replace(/[^a-zA-Z]/g, '');
      }

      function generateHashtag() {
        const n1 = cleanNameForHashtag(name1Input.value.trim());
        const n2 = cleanNameForHashtag(name2Input.value.trim());
        if (!n1 || !n2) return '';
        const year = dateInput.value ? new Date(dateInput.value).getFullYear() : new Date().getFullYear();
        return `#${n1}Y${n2}${year}`;
      }

      function updateHashtagIfAuto() {
        if (!hashtagAuto) return;
        hashtagInput.value = generateHashtag();
        refreshClearButton(hashtagInput);
      }

      [name1Input, name2Input, dateInput].forEach((input) =>
        input.addEventListener('input', updateHashtagIfAuto)
      );

      hashtagInput.addEventListener('input', () => {
        hashtagAuto = false;
      });

      const WEB3FORMS_ACCESS_KEY = '8cb79531-2f65-40a0-8acb-95268fcfdf52';
      const PHOTOS_EMAIL = 'rubenreichelbauman@gmail.com';

      function updatePhotoEmailLinks() {
        const name1 = name1Input.value.trim();
        const name2 = name2Input.value.trim();
        const names = name1 && name2 ? `${name1} y ${name2}` : 'nuestra invitación';

        const subject = `Fotos para la boda de ${names}`;
        const body =
          `Hola, aquí les mando las fotos para nuestra invitación.\n\n` +
          `La foto de portada es: [escribe aquí el nombre del archivo]\n\n` +
          `¡Gracias!`;

        document.getElementById('photo-email-gmail').href =
          `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(PHOTOS_EMAIL)}&su=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        document.getElementById('photo-email-outlook').href =
          `https://outlook.live.com/mail/0/deeplink/compose?to=${encodeURIComponent(PHOTOS_EMAIL)}&subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        document.getElementById('photo-email-default').href =
          `mailto:${PHOTOS_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      }

      [name1Input, name2Input].forEach((input) => input.addEventListener('input', updatePhotoEmailLinks));
      updatePhotoEmailLinks();

      function collectRawEvents() {
        return Array.from(document.querySelectorAll('#events-container .event-block')).map((block) => ({
          name: block.querySelector('.ev-name').value,
          time: block.querySelector('.ev-time').value,
          location: block.querySelector('.ev-location').value,
          address: block.querySelector('.ev-address').value,
          mapEmbedUrl: block.querySelector('.ev-map').value,
        }));
      }

      function collectRawItinerary() {
        return Array.from(document.querySelectorAll('#itinerary-container .itinerary-block')).map((block) => ({
          time: block.querySelector('.it-time').value,
          title: block.querySelector('.it-title').value,
          icon: block.querySelector('.it-icon').value,
        }));
      }

      function collectRawRegistries() {
        return Array.from(document.querySelectorAll('#registries-container .event-block')).map((block) => ({
          label: block.querySelector('.registry-label').value,
          url: block.querySelector('.registry-url').value,
        }));
      }

      function buildDraft() {
        const paletteChecked = document.querySelector('input[name="palette"]:checked');
        return {
          name1: name1Input.value,
          name2: name2Input.value,
          hashtag: hashtagInput.value,
          hashtagAuto,
          theme: themeSelect.value,
          palette: paletteChecked ? paletteChecked.value : null,
          customInk: customInk.value,
          customPaper: customPaper.value,
          customAccent: customAccent.value,
          date: dateInput.value,
          story: document.querySelector('textarea[name="story"]').value,
          dressCode: document.querySelector('input[name="dressCode"]').value,
          rsvpDeadline: document.querySelector('input[name="rsvpDeadline"]').value,
          bankInfo: document.querySelector('textarea[name="bankInfo"]').value,
          events: collectRawEvents(),
          itinerary: collectRawItinerary(),
          registries: collectRawRegistries(),
        };
      }

      function saveDraft() {
        if (!autosaveEnabled) return;
        localStorage.setItem(DRAFT_KEY, JSON.stringify(buildDraft()));
      }

      function clearDraft() {
        localStorage.removeItem(DRAFT_KEY);
      }

      function refreshAllClearButtons() {
        document.querySelectorAll('.clearable-wrap input, .clearable-wrap textarea').forEach(refreshClearButton);
      }

      function restoreDraft(draft) {
        name1Input.value = draft.name1 || '';
        name2Input.value = draft.name2 || '';
        dateInput.value = draft.date || '';
        document.querySelector('textarea[name="story"]').value = draft.story || '';
        document.querySelector('input[name="dressCode"]').value = draft.dressCode || '';
        document.querySelector('input[name="rsvpDeadline"]').value = draft.rsvpDeadline || '';
        document.querySelector('textarea[name="bankInfo"]').value = draft.bankInfo || '';

        if (draft.theme && THEME_PALETTES[draft.theme]) {
          themeSelect.value = draft.theme;
          renderPalettesForTheme(draft.theme);
        }
        if (draft.palette) {
          const radio = document.querySelector(`input[name="palette"][value="${draft.palette}"]`);
          if (radio) {
            radio.checked = true;
            if (draft.palette === 'custom') {
              customColors.hidden = false;
            } else {
              lastPalette = currentPalettes.find((p) => p.key === draft.palette) || lastPalette;
            }
          }
        }
        if (draft.customInk) customInk.value = draft.customInk;
        if (draft.customPaper) customPaper.value = draft.customPaper;
        if (draft.customAccent) customAccent.value = draft.customAccent;
        applyPreviewColors(getSelectedColors());

        hashtagInput.value = draft.hashtag || '';
        hashtagAuto = Boolean(draft.hashtagAuto);

        eventsContainer.innerHTML = '';
        (draft.events || []).forEach((ev) => addEvent(ev));

        itineraryContainer.innerHTML = '';
        (draft.itinerary || []).forEach((item) => addItineraryItem(item));

        registriesContainer.innerHTML = '';
        (draft.registries || []).forEach((r) => addRegistry(r));

        updatePhotoEmailLinks();
        refreshAllClearButtons();
      }

      const draftNotice = document.getElementById('draft-notice');
      const discardDraftBtn = document.getElementById('discard-draft-btn');

      const savedDraftRaw = localStorage.getItem(DRAFT_KEY);
      if (savedDraftRaw) {
        try {
          restoreDraft(JSON.parse(savedDraftRaw));
          draftNotice.hidden = false;
        } catch (err) {
          console.error('No se pudo restaurar el borrador guardado:', err);
          clearDraft();
        }
      }

      discardDraftBtn.addEventListener('click', () => {
        clearDraft();
        window.location.reload();
      });

      autosaveEnabled = true;
      const onboardingForm = document.getElementById('onboarding-form');
      onboardingForm.addEventListener('input', saveDraft);
      onboardingForm.addEventListener('change', saveDraft);

      document.getElementById('onboarding-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const fd = new FormData(form);

        const events = Array.from(document.querySelectorAll('#events-container .event-block'))
          .map((block) => ({
            name: block.querySelector('.ev-name').value.trim(),
            time: block.querySelector('.ev-time').value.trim(),
            location: block.querySelector('.ev-location').value.trim(),
            address: block.querySelector('.ev-address').value.trim(),
            mapEmbedUrl: block.querySelector('.ev-map').value.trim(),
          }))
          .filter((ev) => ev.name || ev.location);

        const itinerary = Array.from(document.querySelectorAll('#itinerary-container .itinerary-block'))
          .map((block) => ({
            time: block.querySelector('.it-time').value.trim(),
            title: block.querySelector('.it-title').value.trim(),
            icon: block.querySelector('.it-icon').value,
          }))
          .filter((item) => item.time || item.title);

        const registries = Array.from(document.querySelectorAll('#registries-container .event-block'))
          .map((block) => ({
            label: block.querySelector('.registry-label').value.trim(),
            url: block.querySelector('.registry-url').value.trim(),
          }))
          .filter((registry) => registry.label || registry.url);

        const name1 = fd.get('name1').trim();
        const name2 = fd.get('name2').trim();

        const config = {
          couple: {
            names: [name1, name2],
            hashtag: fd.get('hashtag').trim(),
          },
          theme: fd.get('theme').trim(),
          colors: getSelectedColors(),
          date: fd.get('date'),
          heroImage: '',
          story: fd.get('story').trim(),
          events,
          itinerary,
          dressCode: fd.get('dressCode').trim(),
          rsvpDeadline: fd.get('rsvpDeadline'),
          gallery: [],
          giftOptions: {
            registries,
            bankInfo: fd.get('bankInfo').trim(),
          },
        };

        const submitBtn = document.getElementById('submit-btn');
        const errorText = document.getElementById('submit-error');
        errorText.hidden = true;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando...';

        const payload = new FormData();
        payload.append('access_key', WEB3FORMS_ACCESS_KEY);
        payload.append('subject', `Nueva boda: ${name1} & ${name2}`);
        payload.append('from_name', `${name1} & ${name2}`);
        payload.append('config_json', JSON.stringify(config, null, 2));

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: payload,
          });
          const result = await response.json();
          if (!result.success) throw new Error(result.message || 'submit failed');

          clearDraft();
          form.hidden = true;
          document.getElementById('thanks-message').textContent =
            `¡Gracias, ${name1} y ${name2}! Ya recibimos su información. No olviden mandarnos sus fotos por correo. Pronto nos pondremos en contacto.`;
          document.getElementById('thanks-section').hidden = false;
          document.getElementById('thanks-section').scrollIntoView({ behavior: 'smooth' });
        } catch (err) {
          console.error('Web3Forms submit error:', err);
          errorText.textContent = `No pudimos enviar la información: ${err.message}`;
          errorText.hidden = false;
          submitBtn.disabled = false;
          submitBtn.textContent = 'Enviar y construir mi invitación';
        }
      });
    </script>
  </body>
</html>
