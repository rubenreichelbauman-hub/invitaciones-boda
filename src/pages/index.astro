---
// src/pages/index.astro
import WeddingLayout from '../layouts/WeddingLayout.astro';
import Hero from '../components/Hero.astro';
import OurStory from '../components/OurStory.astro';
import Itinerary from '../components/Itinerary.astro';
import Gallery from '../components/Gallery.astro';
import LocationSection from '../components/LocationSection.astro';
import RSVP from '../components/RSVP.astro';
import GiftRegistry from '../components/GiftRegistry.astro';
import config from '../data/config.json';
---

<WeddingLayout title={`${config.couple.names[0]} & ${config.couple.names[1]}`}>
  <Hero
    names={config.couple.names}
    date={config.date}
    heroImage={config.heroImage}
  />

  <OurStory story={config.story} />

  <Itinerary items={config.itinerary} />

  <Gallery images={config.gallery} />

  <LocationSection events={config.events} />

  <RSVP deadline={config.rsvpDeadline} />

  <GiftRegistry
    registries={config.giftOptions.registries}
    bankInfo={config.giftOptions.bankInfo}
  />
</WeddingLayout>
