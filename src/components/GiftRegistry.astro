---
// src/components/GiftRegistry.astro
interface Props {
  registryUrl?: string;
  bankInfo?: string; // texto libre: banco, cuenta, referencia
}
const { registryUrl, bankInfo } = Astro.props;
---

{(registryUrl || bankInfo) && (
  <section class="gift-section">
    <p class="section-eyebrow">Mesa de regalos</p>
    <p class="gift-intro">
      Tu presencia es nuestro mejor regalo. Si aún así quieres tener un detalle
      con nosotros, aquí te dejamos algunas opciones.
    </p>

    <div class="gift-options">
      {registryUrl && (
        <a class="gift-card" href={registryUrl} target="_blank" rel="noopener noreferrer">
          <span class="gift-card-label">Mesa de regalos online</span>
          <span class="gift-card-action">Ver mesa →</span>
        </a>
      )}

      {bankInfo && (
        <div class="gift-card">
          <span class="gift-card-label">Depósito o transferencia</span>
          <pre id="bank-info" class="bank-info">{bankInfo}</pre>
          <button class="copy-btn" data-copy={bankInfo}>Copiar datos</button>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .gift-section {
    padding: 6rem 1.5rem;
    background: var(--paper, #F1ECE4);
    color: var(--ink, #2B2320);
    text-align: center;
  }
  .section-eyebrow {
    font-family: var(--font-utility, monospace);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.8rem;
    opacity: 0.6;
    margin-bottom: 1.5rem;
  }
  .gift-intro {
    max-width: 480px;
    margin: 0 auto 2.5rem auto;
    font-size: 0.95rem;
    opacity: 0.8;
    line-height: 1.6;
  }
  .gift-options {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto;
  }
  .gift-card {
    flex: 1 1 260px;
    background: rgba(43, 35, 32, 0.04);
    border: 1px solid rgba(43, 35, 32, 0.12);
    border-radius: 10px;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }
  .gift-card-label {
    font-weight: 500;
    font-size: 0.95rem;
  }
  .gift-card-action {
    font-size: 0.85rem;
    color: var(--accent, #9C7A4A);
  }
  .bank-info {
    font-family: var(--font-utility, monospace);
    font-size: 0.8rem;
    white-space: pre-wrap;
    text-align: left;
    background: rgba(43, 35, 32, 0.05);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    margin: 0;
    width: 100%;
    box-sizing: border-box;
  }
  .copy-btn {
    font-size: 0.8rem;
    background: var(--ink, #2B2320);
    color: var(--paper, #F1ECE4);
    border: none;
    border-radius: 6px;
    padding: 0.5rem 1rem;
    cursor: pointer;
  }
  .copy-btn:hover { opacity: 0.85; }
</style>

<script>
  function initCopyButtons() {
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copy);
          const original = btn.textContent;
          btn.textContent = 'Copiado ✓';
          setTimeout(() => { btn.textContent = original; }, 1800);
        } catch {
          // Silencioso: el usuario aún puede seleccionar y copiar manualmente
        }
      });
    });
  }
  initCopyButtons();
  document.addEventListener('astro:page-load', initCopyButtons);
</script>
