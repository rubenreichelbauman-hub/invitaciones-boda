---
// src/components/Hero.astro
interface Props {
  names: string[];
  date: string;       // ISO string, ej. "2026-11-14T17:00:00"
  heroImage: string;  // ruta a la foto principal
}
const { names, date, heroImage } = Astro.props;
---

<section class="hero" style={`background-image: linear-gradient(0deg, rgba(0,0,0,0.35), rgba(0,0,0,0.15)), url(${heroImage})`}>
  <div class="hero-content">
    <p class="hero-eyebrow">Nos casamos</p>
    <h1 class="hero-names">{names[0]} <span class="amp">&</span> {names[1]}</h1>

    <div id="countdown" class="countdown" data-date={date}>
      <div class="unit"><strong id="cd-days">--</strong><span>días</span></div>
      <div class="unit"><strong id="cd-hours">--</strong><span>hrs</span></div>
      <div class="unit"><strong id="cd-min">--</strong><span>min</span></div>
      <div class="unit"><strong id="cd-sec">--</strong><span>seg</span></div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
    padding: 0 0 8vh 0;
    color: var(--paper, #F1ECE4);
  }
  .hero-content {
    width: 100%;
    text-align: center;
  }
  .hero-eyebrow {
    font-family: var(--font-utility, monospace);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.8rem;
    opacity: 0.85;
    margin-bottom: 0.5rem;
  }
  .hero-names {
    font-family: var(--font-heading, serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    margin: 0 0 2rem 0;
    line-height: 1.1;
  }
  .amp { font-style: italic; opacity: 0.8; }

  .countdown {
    display: flex;
    justify-content: center;
    gap: clamp(1rem, 4vw, 2.5rem);
  }
  .unit {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .unit strong {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
  }
  .unit span {
    font-family: var(--font-utility, monospace);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.75;
    margin-top: 0.25rem;
  }
</style>

<script>
  function initCountdown() {
    const el = document.getElementById('countdown');
    if (!el) return;
    const target = new Date(el.dataset.date).getTime();

    function tick() {
      const diff = Math.max(0, target - Date.now());
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);
      const secs = Math.floor((diff % 60000) / 1000);

      document.getElementById('cd-days').textContent = String(days);
      document.getElementById('cd-hours').textContent = String(hours).padStart(2, '0');
      document.getElementById('cd-min').textContent = String(mins).padStart(2, '0');
      document.getElementById('cd-sec').textContent = String(secs).padStart(2, '0');
    }

    tick();
    setInterval(tick, 1000);
  }

  initCountdown();
  document.addEventListener('astro:page-load', initCountdown);
</script>
