---
// src/components/Itinerary.astro
interface ItineraryItem {
  time: string;        // "17:00" o "17:00 - 18:00"
  title: string;       // "Inicia la ceremonia civil"
  icon?: string;        // clave de ICONS, ej. "church"
}
interface Props {
  items: ItineraryItem[];
}
const { items } = Astro.props;

const ICONS: Record<string, string> = {
  church: `<path d="M12 2v3M10.5 3.5h3M6 9l6-5 6 5M6 9v11h12V9M10 14h4v6h-4z"/>`,
  camera: `<rect x="3" y="7" width="18" height="13" rx="2"/><circle cx="12" cy="13.5" r="3.3"/><path d="M9 7l1.3-2h3.4L15 7"/>`,
  dinner: `<path d="M3 15a9 9 0 0118 0"/><line x1="2" y1="15" x2="22" y2="15"/><line x1="12" y1="7" x2="12" y2="4"/><circle cx="12" cy="3.2" r="0.6" fill="currentColor" stroke="none"/>`,
  toast: `<path d="M8 2h4l-0.6 6a1.7 1.7 0 01-3.4-0.4z"/><line x1="9.6" y1="8" x2="9.6" y2="17"/><path d="M15 4h3.5l-0.5 4.5a1.4 1.4 0 01-2.8 0z"/><line x1="16.5" y1="8.5" x2="16.5" y2="17"/><line x1="7" y1="20" x2="19" y2="20"/><line x1="9.6" y1="17" x2="9.6" y2="20"/><line x1="16.5" y1="17" x2="16.5" y2="20"/>`,
  rings: `<circle cx="9.5" cy="14" r="4.2"/><circle cx="14.5" cy="14" r="4.2"/>`,
  cake: `<path d="M5 21v-6a2 2 0 012-2h10a2 2 0 012 2v6z"/><path d="M5 17h14"/><path d="M9 13V9M15 13V9"/><path d="M12 9V6"/><circle cx="12" cy="4.5" r="0.8" fill="currentColor" stroke="none"/>`,
  party: `<circle cx="9" cy="16" r="2.5"/><path d="M9 13.5V4l8 3.2-6 2.4"/>`,
  heart: `<path d="M12 20s-7.5-4.6-9.7-9C0.8 7.5 2.3 4 5.7 4 8 4 10 5.3 12 7.5 14 5.3 16 4 18.3 4c3.4 0 4.9 3.5 3.4 7-2.2 4.4-9.7 9-9.7 9z"/>`,
};
const DEFAULT_ICON = `<circle cx="12" cy="12" r="3" fill="currentColor" stroke="none"/>`;
---

{items && items.length > 0 && (
  <section class="itinerary-section">
    <p class="section-eyebrow">Itinerario</p>
    <ol class="timeline">
      {items.map((item) => (
        <li class="timeline-item">
          <div class="timeline-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[item.icon ?? ''] ?? DEFAULT_ICON} />
          </div>
          <div class="timeline-content">
            <p class="timeline-time">{item.time}</p>
            <p class="timeline-title">{item.title}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
)}

<style>
  .itinerary-section {
    padding: 6rem 1.5rem;
    background: var(--paper, #F1ECE4);
    color: var(--ink, #2B2320);
    text-align: center;
  }
  .section-eyebrow {
    font-family: var(--font-utility, monospace);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.8rem;
    opacity: 0.6;
    margin-bottom: 2.5rem;
  }
  .timeline {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 420px;
    text-align: left;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.1rem;
    position: relative;
    padding-bottom: 2rem;
  }
  .timeline-item:last-child { padding-bottom: 0; }
  .timeline-item::before {
    content: '';
    position: absolute;
    top: 3rem;
    bottom: -0.5rem;
    left: 1.5rem;
    border-left: 1px dashed rgba(43, 35, 32, 0.3);
  }
  .timeline-item:last-child::before { display: none; }
  .timeline-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 1px solid var(--accent, #9C7A4A);
    background: var(--paper, #F1ECE4);
    color: var(--accent, #9C7A4A);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  .timeline-icon svg {
    width: 1.35rem;
    height: 1.35rem;
  }
  .timeline-content {
    padding-top: 0.4rem;
  }
  .timeline-time {
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0 0 0.2rem 0;
  }
  .timeline-title {
    font-size: 0.85rem;
    opacity: 0.65;
    margin: 0;
    line-height: 1.4;
  }
</style>
