---
// src/layouts/WeddingLayout.astro
import config from '../data/config.json';

interface Props {
  title: string;
}
const { title } = Astro.props;
const { colors } = config;
---

<!doctype html>
<html lang="es" data-theme={config.theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,600;1,400&family=Work+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <style define:vars={{
      ink: colors.ink,
      paper: colors.paper,
      accent: colors.accent,
    }}>
      :root {
        --ink: var(--ink);
        --paper: var(--paper);
        --accent: var(--accent);
        --font-heading: 'Newsreader', serif;
        --font-body: 'Work Sans', sans-serif;
        --font-utility: 'IBM Plex Mono', monospace;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: var(--font-body);
        background: var(--paper);
        color: var(--ink);
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
